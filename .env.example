# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=eyJ...tu-service-role-key
SUPABASE_ANON_KEY=eyJ...tu-anon-key

# Redis (para BullMQ)
REDIS_URL=redis://localhost:6379

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=tu-api-key

# Facebook Lead Ads
FB_VERIFY_TOKEN=tu-token-de-verificacion
FB_APP_SECRET=tu-app-secret
FB_ACCESS_TOKEN=tu-access-token

# Email (SMTP o API)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.tudominio.com
SMTP_PORT=587
SMTP_USER=prospeccion@tudominio.com
SMTP_PASS=tu-password

# App
PORT=3000
NODE_ENV=development
TIMEZONE=America/Argentina/Buenos_Aires

# Audio
AUDIO_STORAGE_PATH=./storage/audios
